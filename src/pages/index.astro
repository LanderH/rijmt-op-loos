---
// Woorden die rijmen op "Loos" (de leerkracht).
// Allemaal "-loos" woorden, want die eindigen letterlijk op zijn naam.
const woorden = [
  // klassiekers
  "hopeloos", "waardeloos", "zinloos", "eindeloos", "machteloos",
  "hulpeloos", "roekeloos", "kleurloos", "sprakeloos", "naamloos",
  "smaakloos", "draadloos", "harteloos", "gevoelloos", "weerloos",
  "grenzeloos", "mateloos", "redeloos", "geluidloos", "bodemloos",
  "vruchteloos", "tijdloos", "feilloos", "stuurloos", "dakloos",
  "werkloos", "kinderloos", "slapeloos", "ademloos", "naadloos",
  "doelloos", "schaamteloos", "hartstochtloos", "humorloos", "stemloos",
  "reddeloos", "rusteloos", "moeiteloos", "vormloos", "zorgeloos",
  "genadeloos", "spoorloos", "wetteloos", "goddeloos", "talloos",
  // extra normale woorden
  "liefdeloos", "eerloos", "smetteloos", "vlekkeloos", "foutloos",
  "pijnloos", "kansloos", "uitzichtloos", "gewichtloos", "geurloos",
  "klankloos", "toonloos", "gedachteloos", "betekenisloos", "nutteloos",
  "contactloos", "energieloos", "krachteloos", "angstloos", "vreugdeloos",
  "fantasieloos", "gewetenloos", "meedogenloos", "emotieloos", "lusteloos",
  "levenloos", "woordeloos", "spraakloos", "kosteloos", "staatloos",
  "wortelloos", "thuisloos", "probleemloos", "zuurstofloos", "peilloos",
  "tomeloos", "principeloos", "karakterloos", "visieloos", "ambitieloos",
  // van de klas zelf
  "dopamineloos", "doornloosje", "cloosje", "speculoosje", "bloos",
];

// De legendarische oneliners van meneer Loos.
const oneliners = [
  "Tijd is relatief en altijd te kort",
  "Wiskunde leuk!",
  "Statistiek geen wiskunde",
  "HATER",
  "CRAPUUL!",
  "LIAM stop met Warre te wurgen!",
  "Stop met wenen",
  "Alles gaat, zelfs een kip gaat en die haar knieën plooien naar achter.",
  "Alles komt goed behalve de rest",
  "In geval van twijfel ga altijd omhoog",
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Er is iets Loos</title>
    <meta name="description" content="Druk op de knop: rijmwoorden en oneliners van meneer Loos." />
  </head>
  <body>
    <main>
      <h1>Er is iets <span class="naam">Loos</span></h1>

      <div class="mascotte-wrapper">
        <img src="data:image/jpeg;base64," alt="Mascotte: Speculoosje" class="mascotte" />
      </div>

      <section class="kaart">
        <h2>Wat rijmt er op Loos?</h2>
        <p class="sub">Druk op de knop en het universum geeft antwoord.</p>
        <div id="resultaat" class="resultaat">???</div>
        <button id="knop">Geef mij een woord</button>
      </section>

      <section class="kaart">
        <h2>Oneliners van Loos</h2>
        <p class="sub">De grootste hits, in willekeurige volgorde.</p>
        <div id="oneliner" class="oneliner">"..."</div>
        <button id="knop2">Geef mij een oneliner</button>
      </section>

      <section class="kaart">
        <h2>Bestaat paars eigenlijk wel?</h2>
        <p class="sub">Een vraag die blijkbaar toch even moet worden uitgeklaard.</p>
        <p class="uitleg">
          Ja, paars bestaat gewoon. Het is een doodgewone kleur, net als rood,
          blauw of groen, en je krijgt het simpelweg door rood en blauw licht
          te mengen. Paars heeft zelfs zijn eigen golflengte ergens tussen de
          380 en 450 nanometer, dus reken maar dat je oog het ook echt ziet.
          Kortom: paars is geen verzinsel, geen optische illusie en geen
          mythe. Gewoon een kleur, zoals alle andere.
        </p>
      </section>

      <section class="kaart">
        <h2>Wat vinden mensen ervan?</h2>
        <p class="sub">Laat een review achter, sterren mogen ook.</p>
        <div id="sterren-input" class="sterren-input" aria-label="Geef een score van 1 tot 5 sterren">
          <span class="ster" data-waarde="1">★</span>
          <span class="ster" data-waarde="2">★</span>
          <span class="ster" data-waarde="3">★</span>
          <span class="ster" data-waarde="4">★</span>
          <span class="ster" data-waarde="5">★</span>
        </div>
        <input id="review-naam" class="veld" type="text" placeholder="Naam (optioneel)" maxlength="40" />
        <textarea id="review-tekst" class="veld" rows="5" placeholder="Wat vond je ervan?" maxlength="5000"></textarea>
        <button id="review-versturen">Review versturen</button>
        <p id="review-melding" class="melding"></p>
        <div id="review-lijst" class="lijst"></div>
      </section>

      <section class="kaart">
        <h2>Nog een woord of zin vergeten?</h2>
        <p class="sub">Gooi je eigen -loos woord of oneliner erbij.</p>
        <textarea id="suggestie-tekst" class="veld" rows="2" placeholder="Bijvoorbeeld: pauzeloos" maxlength="150"></textarea>
        <button id="suggestie-versturen">Suggestie versturen</button>
        <p id="suggestie-melding" class="melding"></p>
        <div id="suggestie-lijst" class="lijst"></div>
      </section>

      <p class="footer">Met liefde gemaakt voor meneer Loos ❤️</p>
    </main>

    <script define:vars={{ woorden, oneliners }}>
      // Maakt een generator die een gekozen item niet laat terugkeren
      // zolang het in de laatste N beurten zat.
      function maakGenerator(lijst, el, transform) {
        const venster = Math.min(20, lijst.length - 1);
        let recent = [];
        return function () {
          let i;
          do {
            i = Math.floor(Math.random() * lijst.length);
          } while (recent.includes(i) && lijst.length > 1);

          recent.push(i);
          if (recent.length > venster) recent.shift();

          el.classList.remove("pop");
          void el.offsetWidth; // forceer reflow zodat de animatie opnieuw start
          el.textContent = transform(lijst[i]);
          el.classList.add("pop");
        };
      }

      const woordEl = document.getElementById("resultaat");
      const onelinerEl = document.getElementById("oneliner");

      document
        .getElementById("knop")
        .addEventListener("click", maakGenerator(woorden, woordEl, (w) => w));

      document
        .getElementById("knop2")
        .addEventListener(
          "click",
          maakGenerator(oneliners, onelinerEl, (z) => `"${z}"`)
        );

      // Reviews en suggesties worden opgeslagen op de server (Cloudflare KV),
      // dus iedereen die de site bezoekt ziet dezelfde lijst.
      async function haalOp(url) {
        try {
          const res = await fetch(url);
          if (!res.ok) return [];
          return await res.json();
        } catch {
          return [];
        }
      }

      async function stuurOp(url, data) {
        try {
          const res = await fetch(url, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(data),
          });
          if (!res.ok) {
            const fout = await res.json().catch(() => ({}));
            return { ok: false, fout: fout.fout || "Er ging iets mis" };
          }
          return { ok: true };
        } catch {
          return { ok: false, fout: "Geen verbinding, probeer opnieuw" };
        }
      }

      function escapeHtml(tekst) {
        const div = document.createElement("div");
        div.textContent = tekst;
        return div.innerHTML;
      }

      function toonMelding(el, tekst) {
        el.textContent = tekst;
        el.classList.add("zichtbaar");
        setTimeout(() => el.classList.remove("zichtbaar"), 2500);
      }

      // --- Reviews ---
      const sterrenWrap = document.getElementById("sterren-input");
      const sterren = sterrenWrap.querySelectorAll(".ster");
      let gekozenScore = 0;

      function tekenSterren() {
        sterren.forEach((s) => {
          s.classList.toggle("actief", Number(s.dataset.waarde) <= gekozenScore);
        });
      }

      sterren.forEach((s) => {
        s.addEventListener("click", () => {
          gekozenScore = Number(s.dataset.waarde);
          tekenSterren();
        });
      });

      async function renderReviews() {
        const el = document.getElementById("review-lijst");
        el.innerHTML = '<p class="leeg">Bezig met laden...</p>';
        const lijst = await haalOp("/api/reviews");
        if (lijst.length === 0) {
          el.innerHTML = '<p class="leeg">Nog geen reviews, wees de eerste.</p>';
          return;
        }
        el.innerHTML = lijst
          .slice()
          .reverse()
          .map((r) => {
            const sterrenTekst = "★".repeat(r.score) + "☆".repeat(5 - r.score);
            const naam = r.naam ? escapeHtml(r.naam) : "Anoniem";
            return `<div class="item">
              <div class="item-kop">
                <span class="item-sterren">${sterrenTekst}</span>
                <span class="item-naam">${naam}</span>
              </div>
              <p class="item-tekst">${escapeHtml(r.tekst)}</p>
            </div>`;
          })
          .join("");
      }

      document.getElementById("review-versturen").addEventListener("click", async () => {
        const naamVeld = document.getElementById("review-naam");
        const tekstVeld = document.getElementById("review-tekst");
        const knop = document.getElementById("review-versturen");
        const melding = document.getElementById("review-melding");

        if (gekozenScore === 0) {
          toonMelding(melding, "Kies eerst een aantal sterren.");
          return;
        }
        if (!tekstVeld.value.trim()) {
          toonMelding(melding, "Schrijf iets in je review.");
          return;
        }

        knop.disabled = true;
        const resultaat = await stuurOp("/api/reviews", {
          naam: naamVeld.value.trim(),
          tekst: tekstVeld.value.trim(),
          score: gekozenScore,
        });
        knop.disabled = false;

        if (!resultaat.ok) {
          toonMelding(melding, resultaat.fout);
          return;
        }

        naamVeld.value = "";
        tekstVeld.value = "";
        gekozenScore = 0;
        tekenSterren();
        toonMelding(melding, "Bedankt voor je review!");
        renderReviews();
      });

      renderReviews();

      // --- Suggesties ---
      async function renderSuggesties() {
        const el = document.getElementById("suggestie-lijst");
        el.innerHTML = '<p class="leeg">Bezig met laden...</p>';
        const lijst = await haalOp("/api/suggesties");
        if (lijst.length === 0) {
          el.innerHTML = '<p class="leeg">Nog geen suggesties binnen.</p>';
          return;
        }
        el.innerHTML = lijst
          .slice()
          .reverse()
          .map((s) => `<div class="item"><p class="item-tekst">${escapeHtml(s.tekst)}</p></div>`)
          .join("");
      }

      document.getElementById("suggestie-versturen").addEventListener("click", async () => {
        const veld = document.getElementById("suggestie-tekst");
        const knop = document.getElementById("suggestie-versturen");
        const melding = document.getElementById("suggestie-melding");
        const tekst = veld.value.trim();

        if (!tekst) {
          toonMelding(melding, "Vul eerst iets in.");
          return;
        }

        knop.disabled = true;
        const resultaat = await stuurOp("/api/suggesties", { tekst });
        knop.disabled = false;

        if (!resultaat.ok) {
          toonMelding(melding, resultaat.fout);
          return;
        }

        veld.value = "";
        toonMelding(melding, "Bedankt voor je suggestie!");
        renderSuggesties();
      });

      renderSuggesties();
    </script>

    <style>
      :root {
        --bg1: #c084fc;
        --bg2: #6d28d9;
        --ink: #2b2b2b;
        --accent: #7c3aed;
        --accent2: #4c1d95;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        background: linear-gradient(135deg, var(--bg1), var(--bg2));
        color: var(--ink);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 1.5rem;
      }
      main {
        width: 100%;
        max-width: 560px;
      }
      h1 {
        font-size: clamp(1.8rem, 6vw, 2.6rem);
        margin: 0 0 1.4rem;
        color: #fff;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
      }
      .kaart {
        background: rgba(255, 255, 255, 0.92);
        border-radius: 24px;
        padding: 2rem 1.6rem;
        margin-bottom: 1.4rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
      }
      h2 {
        margin: 0 0 0.2rem;
        font-size: 1.3rem;
      }
      .sub {
        margin: 0 0 1.4rem;
        opacity: 0.7;
        font-size: 0.95rem;
      }
      .resultaat {
        font-size: clamp(1.8rem, 8vw, 3rem);
        font-weight: 800;
        color: var(--accent);
        min-height: 1.3em;
        margin-bottom: 1.4rem;
        word-break: break-word;
      }
      .oneliner {
        font-size: clamp(1.2rem, 5vw, 1.7rem);
        font-weight: 700;
        font-style: italic;
        color: var(--accent2);
        min-height: 2.6em;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.4rem;
      }
      .uitleg {
        text-align: left;
        line-height: 1.6;
        margin: 0;
        color: var(--ink);
      }
      .mascotte-wrapper {
        margin-bottom: 1.6rem;
      }
      .mascotte {
        width: 200px;
        height: auto;
        border-radius: 20px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
        transition: transform 0.2s ease;
      }
      .mascotte:hover { transform: scale(1.04) rotate(-1deg); }
      .pop { animation: pop 0.35s ease; }
      @keyframes pop {
        0% { transform: scale(0.6); opacity: 0; }
        60% { transform: scale(1.1); }
        100% { transform: scale(1); opacity: 1; }
      }
      button {
        font-size: 1.1rem;
        font-weight: 700;
        padding: 0.85rem 1.7rem;
        border: none;
        border-radius: 999px;
        background: var(--ink);
        color: #fff;
        cursor: pointer;
        transition: transform 0.1s ease, box-shadow 0.2s ease;
        box-shadow: 0 6px 0 rgba(0, 0, 0, 0.25);
      }
      button:hover { transform: translateY(-2px); }
      button:active {
        transform: translateY(4px);
        box-shadow: 0 2px 0 rgba(0, 0, 0, 0.25);
      }
      .footer {
        margin-top: 0.5rem;
        font-size: 0.85rem;
        color: #fff;
        opacity: 0.85;
      }
      .sterren-input {
        font-size: 2rem;
        margin-bottom: 1rem;
        line-height: 1;
      }
      .ster {
        cursor: pointer;
        color: #d8d8d8;
        transition: color 0.1s ease, transform 0.1s ease;
        display: inline-block;
      }
      .ster:hover { transform: scale(1.1); }
      .ster.actief { color: #f5a623; }
      .veld {
        width: 100%;
        font-family: inherit;
        font-size: 1rem;
        padding: 0.7rem 0.9rem;
        border: 2px solid #e2e2e2;
        border-radius: 12px;
        margin-bottom: 0.8rem;
        resize: vertical;
        color: var(--ink);
      }
      .veld:focus {
        outline: none;
        border-color: var(--accent);
      }
      .melding {
        min-height: 1.2em;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--accent);
        opacity: 0;
        transition: opacity 0.2s ease;
        margin: 0.6rem 0 0;
      }
      .melding.zichtbaar { opacity: 1; }
      .lijst {
        text-align: left;
        margin-top: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        max-height: 280px;
        overflow-y: auto;
      }
      .lijst .leeg {
        text-align: center;
        opacity: 0.6;
        font-size: 0.9rem;
        margin: 0;
      }
      .item {
        background: #f7f5fb;
        border-radius: 12px;
        padding: 0.7rem 0.9rem;
      }
      .item-kop {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        margin-bottom: 0.3rem;
      }
      .item-sterren {
        color: #f5a623;
        letter-spacing: 1px;
      }
      .item-naam {
        font-weight: 700;
        font-size: 0.85rem;
        opacity: 0.75;
      }
      .item-tekst {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.4;
        word-break: break-word;
      }
    </style>
  </body>
</html>